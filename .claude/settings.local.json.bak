{
  "permissions": {
    "allow": [
      "mcp__claude_ai_Context7__resolve-library-id",
      "Bash(python -m venv .venv)",
      "Bash(.venv/Scripts/pip install:*)",
      "Bash(.venv/Scripts/python -m pytest --co -q)",
      "Bash(.venv/Scripts/python -m pytest tests/test_models.py -v 2>&1)"
    ]
  },
  "mcpServers": {
    "pare-git": {
      "command": "cmd",
      "args": [
        "/c",
        "npx",
        "-y",
        "@paretools/git"
      ]
    },
    "pare-python": {
      "command": "cmd",
      "args": [
        "/c",
        "npx",
        "-y",
        "@paretools/python"
      ]
    },
    "pare-test": {
      "command": "cmd",
      "args": [
        "/c",
        "npx",
        "-y",
        "@paretools/test"
      ]
    }
  }
}
